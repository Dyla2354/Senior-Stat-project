raw_data <- read.csv("data2000.csv")  # Open file chooser to load CSV
data <- raw_data                     # Make a working copy
summary(data)  
head(data)                           # Quick check of the first few rows
 

# --------------------------------------------------------
# 1. Filter and Prepare Data (2007-2023)
# --------------------------------------------------------
df_clean <- data %>%
  filter(Year.of.diagnosis >= 2007 & Year.of.diagnosis <= 2023) %>%
  rename(Age_range = `Age.recode.with..1.year.olds.and.90.`)%>%
  mutate(
    Start_Year = Year.of.diagnosis - (Year.of.diagnosis - 2007) %% 2,
    NHANES_cycle = paste0(Start_Year, "-", Start_Year + 1),
    Age_range = gsub(" years", "", Age_range),
    Age_group = case_when(
      Age_range < 40  ~ "<40",
      Age_range >= 40 & Age_range <= 44 ~ "40-44",
      Age_range >= 45 & Age_range <= 49 ~ "45-49",
      Age_range >= 50 ~ "50+",
      TRUE ~ NA_character_),
    Age_group = factor(Age_group, levels = c("<40", "40-44", "45-49", "50+")))

# --------------------------------------------------------
# 3. Calculate Proportions and Counts
# --------------------------------------------------------
cycle_summary <- df_clean %>%
  group_by(NHANES_cycle, Start_Year, Age_group) %>%
  summarise(Cases = n(), .groups = "drop") %>%
  group_by(NHANES_cycle) %>%
  mutate(
    Total_Cycle_Cases = sum(Cases),
    Proportion = Cases / Total_Cycle_Cases
  )

# --------------------------------------------------------
# 4. Visualization: Trends by the 4 Age Groups
# --------------------------------------------------------
cycle_summary_faceted <- cycle_summary %>%
  mutate(Plot_Group = ifelse(Age_group == "50+", "Older Cohort (50+)", "Younger Cohorts (<50)"))

#Plot proportion
ggplot(cycle_summary_faceted, aes(x = NHANES_cycle, y = Proportion, group = Age_group, color = Age_group)) +
  geom_line(size = 1.2) +
  geom_point(size = 3) +
  # 'scales = "free_y"' is crucial so the <50 trends aren't flattened by the 50+ scale
  facet_wrap(~ Plot_Group, scales = "free_y", ncol = 1) + 
  scale_y_continuous(labels = percent) +
  theme_minimal() +
  labs(
    title = "Colorectal Cancer Proportion Trends (2007-2020)",
    subtitle = "Faceted by Age Cohort (Note different Y-axis scales)",
    x = "NHANES Cycle", 
    y = "Proportion of Total Cases",
    color = "Age Group"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    strip.text = element_text(face = "bold", size = 12) # Makes facet titles pop
  )

# Actual cases
ggplot(cycle_summary_faceted, aes(x = NHANES_cycle, y = Cases, group = Age_group, color = Age_group)) +
  geom_line(linewidth = 1.2) +
  geom_point(size = 3) +
  # 'free_y' allows the 50+ and <50 groups to have their own Y-axis scales
  facet_wrap(~ Plot_Group, scales = "free_y", ncol = 1) + 
  scale_y_continuous(labels = label_comma()) + # Formats numbers with commas (e.g., 10,000)
  theme_minimal() +
  labs(
    title = "Total Number of Colorectal Cancer Cases (2007-2020)",
    subtitle = "Trends in raw counts by age cohort",
    x = "NHANES Cycle", 
    y = "Total Number of Cases",
    color = "Age Group"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    strip.text = element_text(face = "bold", size = 12)
  )


# --------------------------------------------------------
# 5. Statistical Analysis: Negative Binomial Regression
# --------------------------------------------------------
# We focus on cases < 50 (the three younger groups combined)
nb_data <- cycle_summary %>%
  filter(Age_group != "50+") %>%
  group_by(Start_Year) %>%
  summarise(Young_Cases = sum(Cases), Total_Cases = sum(Total_Cycle_Cases))

# Negative Binomial Model
# Using log(Total_Cases) as an offset to model the RATE of occurrence
nb_model <- glm.nb(Young_Cases ~ Start_Year + offset(log(Total_Cases)), data = nb_data)

summary(nb_model)

