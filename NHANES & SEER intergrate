# --- 1. CONFIGURATION ---
# Define cycles and labels in one place
cycles <- list(
  suffix = c("E", "F", "G", "H", "I", "P","L"),
  label  = c("2007-2008", "2009-2010", "2011-2012", "2013-2014", "2015-2016", "2017-2020", "2021-2023")
)

# --- 2. OPTIMIZED FETCH FUNCTION ---
fetch_nhanes_cleaned <- function(s, label) {
  prefix <- if(s == "P") "P_" else ""
  suffix <- if(s == "P") "" else paste0("_", s)
  
  # 1. Download tables
  demo_raw <- nhanes(paste0(prefix, "DEMO", suffix))
  bmx_raw  <- nhanes(paste0(prefix, "BMX", suffix))
  paq_raw  <- nhanes(paste0(prefix, "PAQ", suffix))
  
  if (any(sapply(list(demo_raw, bmx_raw, paq_raw), is.null))) return(NULL)
  
  # 2. Identify which weight column 
  weight_col <- intersect(c("WTMEC2YR", "WTMECPRP"), names(demo_raw))
  
  # 3. Join and Clean
  df <- demo_raw %>%
    dplyr::select(SEQN, any_of(weight_col), SDMVSTRA, SDMVPSU, RIDAGEYR) %>%
    inner_join(dplyr::select(bmx_raw, SEQN, BMXBMI), by = "SEQN") %>%
    inner_join(dplyr::select(paq_raw, SEQN, PAD680), by = "SEQN") %>%
    rename(raw_weight = !!weight_col) %>% 
    mutate(
      NHANES_cycle = label,
      is_obese = as.numeric(BMXBMI >= 30),
      is_high_sedentary = case_when(
        PAD680 > 480 & PAD680 < 7777 ~ 1,
        PAD680 <= 480                ~ 0,
        TRUE                         ~ NA_real_
      ),
      Age_group = case_when(
        RIDAGEYR < 40 ~ "<40",
        RIDAGEYR >= 40 & RIDAGEYR <= 44 ~ "40-44",
        RIDAGEYR >= 45 & RIDAGEYR <= 49 ~ "45-49",
        RIDAGEYR >= 50 ~ "50+",
        TRUE ~ "Other"
      )
    ) %>%
    filter(Age_group != "Other")
  
  return(df)
}

# --- 3. EXECUTION & DESIGN ---
all_data <- map2_dfr(cycles$suffix, cycles$label, fetch_nhanes_cleaned) %>%
  mutate( 
    NHANES_cycle = if_else(NHANES_cycle == "2021-2023", "2021-2022", NHANES_cycle),
    cycle_num = as.numeric(factor(NHANES_cycle, levels = c("2007-2008", "2009-2010", "2011-2012", 
                                                           "2013-2014", "2015-2016", "2017-2020", 
                                                           "2021-2022"))),
    adj_weight = raw_weight / length(unique(NHANES_cycle))
  )

#--- Single Survey Design Object
trend_design <- svydesign(
  id = ~SDMVPSU, strata = ~SDMVSTRA, weights = ~adj_weight, 
  nest = TRUE, data = all_data
)

# --- 5. STREAMLINED ANALYSIS ---
get_prev <- function(formula, design, name) {
  svyby(formula, ~NHANES_cycle + Age_group, design, svymean, na.rm = TRUE) %>%
    rename(prev = 3) %>% 
    mutate(Metric = name, pct = prev * 100, se_pct = se * 100)
}

plot_data <- bind_rows(
  get_prev(~is_obese, trend_design, "Obesity"),
  get_prev(~is_high_sedentary, trend_design, "High Sedentary")
)

ggplot(plot_data, aes(x = NHANES_cycle, y = pct, color = Age_group, group = Age_group)) +
  geom_line(size = 1.2) +
  geom_point(size = 3) +
  geom_errorbar(aes(ymin = pct - (1.96 * se_pct), ymax = pct + (1.96 * se_pct)), width = 0.2) +
  facet_wrap(~Metric, scales = "free_y", ncol = 1) +
  theme_minimal() +
  labs(
    title = "Long-term Health Trends: NHANES 2007-2023",
    subtitle = "Analysis of Obesity and Sedentary Behavior in Adults under 50",
    x = "Survey Cycle",
    y = "Estimated Prevalence (%)",
    color = "Age Group"
  ) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

## ---- Regression model----- 
all_data <- all_data %>%
  mutate(NHANES_cycle = if_else(NHANES_cycle == "2021-2023", "2021-2022", NHANES_cycle),
         cycle_num = as.numeric(factor(NHANES_cycle, levels = c("2007-2008", "2009-2010", "2011-2012", 
                                                                "2013-2014", "2015-2016", "2017-2020", 
                                                                "2021-2022"))))

options(survey.lonely.psu = "adjust")

trend_design_final <- svydesign(
  id = ~SDMVPSU, 
  strata = ~SDMVSTRA, 
  weights = ~adj_weight, 
  nest = TRUE, 
  data = all_data
)

# Adjusted Logistic Regression (Obesity)
obese_mod <- svyglm(
  is_obese ~ cycle_num * Age_group, 
  design = trend_design_final, 
  family = quasibinomial()
)
summary(obese_mod)
# Adjusted Logistic Regression (High Sedentary)
sedentary_mod <- svyglm(
  is_high_sedentary ~ cycle_num * Age_group, 
  design = trend_design_final, 
  family = quasibinomial()
)
summary(sedentary_mod)


# Generate predicted probabilities
pred_obese <- ggpredict(obese_mod, terms = c("cycle_num", "Age_group"))%>%
  cbind.data.frame("Metric"=c("Obese"))
pred_sedentary <- ggpredict(sedentary_mod, terms = c("cycle_num", "Age_group"))%>%
  cbind.data.frame("Metric"=c("Sedentary"))

combined_trends <- bind_rows(pred_obese, pred_sedentary) %>%
  filter(group != "Other")

# Plotting the adjusted trend
updated_labels <- cycles$label
updated_labels[updated_labels == "2021-2023"] <- "2021-2022"

ggplot(combined_trends, aes(x = x, y = predicted, color = group, fill = group)) +
  geom_ribbon(aes(ymin = conf.low, ymax = conf.high), alpha = 0.15, color = NA) + 
  geom_line(linewidth = 1.2) +
  geom_point(size = 2) +
  
  facet_wrap(~Metric) +
  
  scale_x_continuous(breaks = 1:7, labels = updated_labels) +
  scale_y_continuous(labels = scales::percent_format(), limits = c(0, NA)) +
  
  scale_color_manual(values = c("#E69F00", "#56B4E9","#9932CC", "#009E73" )) +
  scale_fill_manual(values = c("#E69F00", "#56B4E9","#9932CC","#009E73")) +

  theme_minimal() +
  labs(
    title = "U.S. Health Trends by Age Group (2007-2023*)",
    subtitle = "Modeled Predicted Probabilities from NHANES Survey Data",
    x = "Survey Cycle",
    y = "Predicted Probability (%)",
    color = "Age Group",
    fill = "Age Group"
  ) +
  theme(
    legend.position = "bottom",
    strip.text = element_text(face = "bold", size = 12),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )


